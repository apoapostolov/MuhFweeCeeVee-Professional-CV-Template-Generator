{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myfreeceevee.local/cv-keyword-analysis/analysis_input.schema.json",
  "title": "CV Keyword Analysis Input",
  "type": "object",
  "required": ["cv", "jd_corpus"],
  "properties": {
    "cv": {
      "type": "object",
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "jd_corpus": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "text": { "type": "string", "minLength": 1 },
          "score": { "type": "number" },
          "source_url": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "weighted_keywords": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "section_weights": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "top_n_keywords": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
